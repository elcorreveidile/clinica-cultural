// Clínica Cultural y Lingüística de Español — Prisma schema
// Stack: Neon (PostgreSQL) + Prisma ORM. Auth: Magic Link propio (sin NextAuth).

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum UserRole {
  patient
  tutor_local
  professor
  admin
}

enum LanguageLevel {
  A1
  A2
  B1
  B2
  C1
  C2
}

enum CardStatus {
  active
  inactive
  expired
}

enum MentorshipStatus {
  pending
  active
  completed
}

enum FarmaciaCategory {
  grammar
  vocabulary
  cultural
  conversation
  writing
  audiovisual
}

enum ContentType {
  video
  text
  exercise
  interactive
  podcast
}

enum ResourceType {
  pill
  ointment
  syrup
  injection
}

enum PortfolioContentType {
  writing
  audio
  video
  miniseries_episode
  project
}

enum Visibility {
  private
  shared_with_professor
  public
}

enum ActivityType {
  ruta_tapas
  museo
  cine
  teatro
  taller
  debate
  safari_fotografico
}

enum SessionStatus {
  scheduled
  completed
  cancelled
}

// ---------------------------------------------------------------------------
// Auth: usuarios, magic-link tokens y sesiones
// ---------------------------------------------------------------------------

model User {
  id                String         @id @default(uuid()) @db.Uuid
  email             String         @unique
  fullName          String?        @map("full_name")
  role              UserRole       @default(patient)
  dateOfBirth       DateTime?      @map("date_of_birth")
  nationality       String?
  nativeLanguage    String?        @map("native_language")
  currentLevel      LanguageLevel? @map("current_level")
  // Matrícula del alumno: null/ninguno | mensual | trimestral. Define el cupo
  // de tutorías con profesorado (mensual: 2, trimestral: 8). A futuro lo fijará
  // el sistema de pagos; de momento lo asigna el admin.
  plan              String?
  profilePictureUrl String?        @map("profile_picture_url")
  bio               String?
  phone             String?
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")

  // Relaciones
  magicLinkTokens MagicLinkToken[]
  sessions        Session[]
  diagnoses       Diagnosis[]
  seguroLC        SeguroLC?
  tutoredSeguros  SeguroLC[]            @relation("TutorOfSeguro")
  portafolio      Portafolio[]
  chatMessages    ChatLineaEmergencia[]
  tutorSessions   SesionTutoria[]       @relation("TutorSessions")
  patientSessions SesionTutoria[]       @relation("PatientSessions")
  reservas        Reserva[]

  @@map("users")
}

enum ReservaEstado {
  confirmada
  cancelada
}

/// Reserva de una actividad del catálogo (el catálogo es estático: lib/actividades.ts).
model Reserva {
  id          String        @id @default(uuid()) @db.Uuid
  userId      String        @map("user_id") @db.Uuid
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  actividadId String        @map("actividad_id")
  estado      ReservaEstado @default(confirmada)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  @@unique([userId, actividadId])
  @@index([userId])
  @@map("reservas")
}

model MagicLinkToken {
  id        String    @id @default(uuid()) @db.Uuid
  tokenHash String    @unique @map("token_hash")
  email     String
  userId    String?   @map("user_id") @db.Uuid
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([email])
  @@map("magic_link_tokens")
}

model Session {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("sessions")
}

// ---------------------------------------------------------------------------
// Diagnóstico lingüístico
// ---------------------------------------------------------------------------

model Diagnosis {
  id                          String         @id @default(uuid()) @db.Uuid
  userId                      String         @map("user_id") @db.Uuid
  user                        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  diagnosisDate               DateTime       @default(now()) @map("diagnosis_date")
  grammarScore                Int?           @map("grammar_score")
  listeningComprehensionScore Int?           @map("listening_comprehension_score")
  readingComprehensionScore   Int?           @map("reading_comprehension_score")
  writtenExpressionScore      Int?           @map("written_expression_score")
  assessedLevel               LanguageLevel? @map("assessed_level")
  interviewNotes              String?        @map("interview_notes")
  linguisticStrengths         String?        @map("linguistic_strengths")
  linguisticWeaknesses        String?        @map("linguistic_weaknesses")
  recommendedFarmacias        Json?          @map("recommended_farmacias")
  initialTreatmentPlan        String?        @map("initial_treatment_plan")
  createdAt                   DateTime       @default(now()) @map("created_at")
  completedAt                 DateTime?      @map("completed_at")

  @@index([userId])
  @@map("diagnoses")
}

// ---------------------------------------------------------------------------
// Seguro Lingüístico y Cultural (Seguro LC)
// ---------------------------------------------------------------------------

model SeguroLC {
  id                     String            @id @default(uuid()) @db.Uuid
  userId                 String            @unique @map("user_id") @db.Uuid
  user                   User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  cardNumber             String            @unique @map("card_number")
  cardStatus             CardStatus        @default(active) @map("card_status")
  issuedDate             DateTime          @default(now()) @map("issued_date")
  expiryDate             DateTime?         @map("expiry_date")
  qrCodeData             String?           @map("qr_code_data")
  qrCodeImageUrl         String?           @map("qr_code_image_url")
  linkedTutorId          String?           @map("linked_tutor_id") @db.Uuid
  linkedTutor            User?             @relation("TutorOfSeguro", fields: [linkedTutorId], references: [id])
  mentorshipStatus       MentorshipStatus? @map("mentorship_status")
  mentorshipStartDate    DateTime?         @map("mentorship_start_date")
  discountedActivities   Json?             @map("discounted_activities")
  mentoringSessionsUsed  Int               @default(0) @map("mentoring_sessions_used")
  mentoringSessionsTotal Int               @default(12) @map("mentoring_sessions_total")
  createdAt              DateTime          @default(now()) @map("created_at")
  updatedAt              DateTime          @updatedAt @map("updated_at")

  sessions SesionTutoria[]

  @@map("seguros_lc")
}

// ---------------------------------------------------------------------------
// Farmacias lingüísticas y recursos
// ---------------------------------------------------------------------------

model Farmacia {
  id             String            @id @default(uuid()) @db.Uuid
  name           String
  // Categoría libre (texto) para permitir nuevas farmacias en el futuro
  // (enfermería, clínica del habla, olores y sabores…), sin un enum cerrado.
  category       String?
  targetLevel    LanguageLevel?    @map("target_level")
  iconUrl        String?           @map("icon_url")
  description    String?
  resourcesCount Int?              @map("resources_count")
  createdAt      DateTime          @default(now()) @map("created_at")

  recursos Recurso[]

  @@map("farmacias")
}

model Recurso {
  id              String         @id @default(uuid()) @db.Uuid
  farmaciaId      String         @map("farmacia_id") @db.Uuid
  farmacia        Farmacia       @relation(fields: [farmaciaId], references: [id], onDelete: Cascade)
  title           String
  contentType     ContentType?   @map("content_type")
  resourceType    ResourceType?  @map("resource_type")
  contentUrl      String?        @map("content_url")
  description     String?
  durationMinutes Int?           @map("duration_minutes")
  difficultyLevel LanguageLevel? @map("difficulty_level")
  // Contenido gestionable desde el editor (paso 3: contenido en BD).
  content         String?        // cuerpo en markdown
  lexico          Json?          // mapa palabra→definición (RAE)
  dosis           String?        // pildora | jarabe | pomada | inyeccion
  formato         String?        // texto | ejercicio | video | audio | interactivo
  posicion        Int?           // orden dentro de la farmacia
  slug            String?        // clave estable (para importación idempotente)
  createdAt       DateTime       @default(now()) @map("created_at")

  @@index([farmaciaId])
  @@map("recursos")
}

// ---------------------------------------------------------------------------
// Portafolio del estudiante
// ---------------------------------------------------------------------------

model Portafolio {
  id                    String               @id @default(uuid()) @db.Uuid
  userId                String               @map("user_id") @db.Uuid
  user                  User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  title                 String
  description           String?
  contentType           PortfolioContentType @map("content_type")
  fileUrl               String?              @map("file_url")
  thumbnailUrl          String?              @map("thumbnail_url")
  durationMinutes       Int?                 @map("duration_minutes")
  visibility            Visibility           @default(private)
  professorFeedback     String?              @map("professor_feedback")
  professorFeedbackDate DateTime?            @map("professor_feedback_date")
  versionNumber         Int                  @default(1) @map("version_number")
  previousVersionId     String?              @map("previous_version_id") @db.Uuid
  previousVersion       Portafolio?          @relation("PortfolioVersions", fields: [previousVersionId], references: [id])
  nextVersions          Portafolio[]         @relation("PortfolioVersions")
  createdAt             DateTime             @default(now()) @map("created_at")
  updatedAt             DateTime             @updatedAt @map("updated_at")

  @@index([userId])
  @@map("portafolio")
}

// ---------------------------------------------------------------------------
// Actividades culturales
// ---------------------------------------------------------------------------

model ActividadCultural {
  id                      String        @id @default(uuid()) @db.Uuid
  name                    String
  type                    ActivityType?
  description             String?
  location                String?
  dateTime                DateTime?     @map("date_time")
  durationMinutes         Int?          @map("duration_minutes")
  maxParticipants         Int?          @map("max_participants")
  currentParticipants     Int           @default(0) @map("current_participants")
  priceEuros              Decimal?      @map("price_euros") @db.Decimal(10, 2)
  seguroLcDiscountPercent Int           @default(20) @map("seguro_lc_discount_percent")
  languageLevelTarget     String?       @map("language_level_target")
  imageUrl                String?       @map("image_url")
  createdAt               DateTime      @default(now()) @map("created_at")

  @@map("actividades_culturales")
}

// ---------------------------------------------------------------------------
// Línea de Emergencia Lingüística (Chat IA con Claude)
// ---------------------------------------------------------------------------

model ChatLineaEmergencia {
  id                   String         @id @default(uuid()) @db.Uuid
  userId               String?        @map("user_id") @db.Uuid
  user                 User?          @relation(fields: [userId], references: [id])
  conversationId       String         @default(uuid()) @map("conversation_id") @db.Uuid
  userMessage          String         @map("user_message")
  aiResponse           String         @map("ai_response")
  languageLevelContext LanguageLevel? @map("language_level_context")
  createdAt            DateTime       @default(now()) @map("timestamp")

  @@index([userId])
  @@index([conversationId])
  @@map("chat_linea_emergencia")
}

// ---------------------------------------------------------------------------
// Sesiones de tutoría
// ---------------------------------------------------------------------------

model SesionTutoria {
  id              String         @id @default(uuid()) @db.Uuid
  seguroLcId      String?        @map("seguro_lc_id") @db.Uuid
  seguroLC        SeguroLC?      @relation(fields: [seguroLcId], references: [id])
  tutorId         String?        @map("tutor_id") @db.Uuid
  tutor           User?          @relation("TutorSessions", fields: [tutorId], references: [id])
  patientId       String?        @map("patient_id") @db.Uuid
  patient         User?          @relation("PatientSessions", fields: [patientId], references: [id])
  scheduledDate   DateTime?      @map("scheduled_date")
  actualDate      DateTime?      @map("actual_date")
  durationMinutes Int            @default(60) @map("duration_minutes")
  notes           String?
  status          SessionStatus? @default(scheduled)
  createdAt       DateTime       @default(now()) @map("created_at")

  @@map("sesiones_tutoria")
}
