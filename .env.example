# Copia este archivo a .env y rellena tus credenciales.

# Base de datos Neon (PostgreSQL)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Resend — envío de Magic Link por email
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
EMAIL_FROM="Clínica Cultural <onboarding@resend.dev>"

# Claude API — chat de la Línea de Emergencia Lingüística
CLAUDE_API_KEY="sk-ant-xxxxxxxxxxxxxxxxxxxx"
CLAUDE_MODEL="claude-sonnet-4-6"

# Stripe (pagos — futuro)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_xxxxxxxx"
STRIPE_SECRET_KEY="sk_test_xxxxxxxx"

# Sesiones — firma de cookies (openssl rand -base64 32)
SESSION_SECRET="genera-un-secreto-largo-aleatorio"

# General
NEXT_PUBLIC_URL="http://localhost:3000"
NODE_ENV="development"
